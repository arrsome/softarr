# =============================================================================
# Softarr Configuration
# =============================================================================

# Database (required)
# For local SQLite testing (dev/ is gitignored):
DATABASE_URL=sqlite+aiosqlite:///./dev/softarr.db

# Security (CHANGE THESE IN PRODUCTION)
SECRET_KEY=generate-a-real-secret-key-here
DEBUG=true

# Admin bootstrap -- on first run with no users in DB, an admin account
# is created. If ADMIN_PASSWORD_HASH is empty, a random password is
# generated and printed to the console. To pre-set the password, generate
# a bcrypt hash:  python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Session lifetime in seconds (default 24 hours)
SESSION_MAX_AGE_SECONDS=86400

# CORS -- restrict to your actual origins in production
CORS_ORIGINS=["http://localhost:8000"]
CORS_ALLOW_ALL=false

# Auto-create tables on startup (dev only; use Alembic in production)
AUTO_CREATE_TABLES=true

# GitHub adapter
GITHUB_TOKEN=

# SABnzbd integration (can also be configured via Settings UI)
SABNZBD_URL=
SABNZBD_API_KEY=
SABNZBD_CATEGORY=software

# Rate limiting
RATE_LIMIT_SEARCH=10/minute
RATE_LIMIT_DEFAULT=60/minute
